        <!-- Варианты использования (эллипсы, как в UML) -->
        <mxCell id="uc1" value="Формирование отчёта о состоянии заявок" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=11;fontFamily=Arial;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1">
